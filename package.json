{
  "name": "tech-blog",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "prepare": "pnpm build-sw",
    "dev": "next dev --webpack -p 4321",
    "prebuild": "tsx scripts/generate-seo.ts",
    "build": "pnpm build-sw && next build --webpack",
    "build-sw": "tsx scripts/generate-sw-precache.ts && esbuild lib/sw.ts --bundle --outfile=public/sw.js",
    "seo:generate": "tsx scripts/generate-seo.ts",
    "indexnow": "tsx scripts/indexnow-ping.ts",
    "start": "next start -p 4321",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:posts": "tsx scripts/format-post.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier": "^3.8.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
